# Copy this file to .env.local and fill in your values

# Core app
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_long_random_secret

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=lendstack
MONGODB_DB_NAME=jvf

# Stripe SaaS billing
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_STARTER_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_STARTER_YEARLY=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_PRO_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_PRO_YEARLY=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_ENTERPRISE_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxx

# Stripe Connect
STRIPE_CONNECT_RETURN_URL=http://localhost:3000/app?connect=return
STRIPE_CONNECT_REFRESH_URL=http://localhost:3000/app?connect=refresh

# Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Blob storage
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx
