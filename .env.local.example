# Copy this file to .env.local and fill in your values

# ── Email sending (Resend - https://resend.com) ───────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Neo4j database (https://neo4j.com/cloud/platform/aura-graph-database/) ───
# Create a free AuraDB instance and copy the connection details below.
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ── Vercel Blob — document uploads (https://vercel.com/docs/storage/vercel-blob)
# Required to upload client documents larger than 500 KB.
# Generate a token in your Vercel project → Storage → Blob.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# ── Optional: Live currency exchange rates (https://exchangeratesapi.io) ──────
# NEXT_PUBLIC_EXCHANGE_API_KEY=your_key_here
